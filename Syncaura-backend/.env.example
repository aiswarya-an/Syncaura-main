# Server Configuration
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES= time_in_minute
JWT_REFRESH_EXPIRES= time_in_minute

# Reset password
RESET_TOKEN_SECRET=your_reset_token_secret_here
RESET_TOKEN_EXPIRES_MIN= time_in_minute

# Email (Ethereal for dev)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your_ethereal_username
EMAIL_PASS=your_ethereal_password
EMAIL_FROM=your_ethereal_email@example.com

# Client

# JWT Access Secret (used in code)
JWT_ACCESS_SECRET=dummyaccesssecret

# Slack Bot Configuration
SLACK_BOT_TOKEN=dummyslackbottoken
SLACK_SIGNING_SECRET=dummyslacksigningsecret
SLACK_APP_TOKEN=dummyslackapptoken

# GitHub API Configuration (optional)
GITHUB_CLIENT_ID=dummygithubclientid
GITHUB_CLIENT_SECRET=dummygithubclientsecret
CLIENT_URL=http://localhost:3000

# Google Calendar (optional)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json



# Server Authentication
RESET_TOKEN_SECRET=your_reset_token_secret_here
RESET_TOKEN_EXPIRES_MIN= time_in_minute
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_ACCESS_EXPIRES= time_in_days
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES=time_in_days

## Slack Bot Configuration
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_APP_TOKEN=your_slack_app_token_here

